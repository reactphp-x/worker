{
    "name": "reactphp-x/worker",
    "description": "Multi-process master/worker model for PHP CLI",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "ReactX\\Worker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ReactX\\Worker\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "react/event-loop": "^1.6"
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable"
}
